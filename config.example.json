{
  "business": {
    "name": "YOUR_BUSINESS_NAME",
    "timezone": "YOUR_TIMEZONE"
  },
  "db": {
    "url": "postgresql://ai_crm_user:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/ai_crm"
  },
  "claude": {
    "bin": "claude",
    "flags": ["--dangerously-skip-permissions"],
    "model": "claude-sonnet-4-6"
  },
  "web": {
    "port": 8080
  },
  "contacts": [
    {"type": "TYPE_1", "label": "Label 1", "path": "wiki/path/to/type1"},
    {"type": "TYPE_2", "label": "Label 2", "path": "wiki/path/to/type2"},
    {"type": "lead",   "label": "Lead",    "path": "wiki/leads"}
  ],
  "quick_questions": [
    "Any urgent matters?",
    "Who needs follow-up?",
    "Today's schedule",
    "Stock levels",
    "Recent leads",
    "Overdue clients"
  ],
  "channels": {
    "telegram": {
      "bot_token": "YOUR_BOT_TOKEN",
      "chat_id": "YOUR_GROUP_CHAT_ID",
      "topics": {
        "external": 0,
        "internal": 0
      },
      "owners": ["YOUR_TELEGRAM_USER_ID"]
    }
  }
